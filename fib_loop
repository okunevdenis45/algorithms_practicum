import time


def fib(n):
    """
    Функция для вычисления n-го числа Фибоначчи с использованием цикла.
    Принимает целое число n (1 <= n <= 32) и выводит результат на экран.
    """
    # Базовые случаи
    if n == 1:
        print(1)
        return
    elif n == 2:
        print(1)
        return

    # Инициализируем первые два числа последовательности
    prev = 1  # F(1)
    curr = 1  # F(2)

    # Цикл от 3 до n (включительно)
    for i in range(3, n + 1):
        next_fib = prev + curr  # Вычисляем следующее число
        prev = curr  # Сдвигаем "окно": предыдущее становится текущим
        curr = next_fib  # текущее становится следующим

    print(curr)  # Выводим итоговое n-ое число


def measure_time(n):
    """
    Функция для замера времени выполнения с точностью до миллисекунды.
    """
    start_time = time.time()
    fib(n)
    end_time = time.time()

    # Вычисляем время в миллисекундах
    execution_time_ms = (end_time - start_time) * 1000
    return execution_time_ms


# Основная часть программы: тестирование и замеры
print("Вычисление чисел Фибоначчи с помощью цикла")
print("=" * 50)

# Выбираем произвольные значения n для замеров (в пределах 1 <= n <= 32)
test_values = [5, 10, 15, 25, 32]

for n in test_values:
    time_ms = measure_time(n)
    print(f"fib({n}) | Время выполнения: {time_ms:.6f} мс")

print("\n" + "=" * 50)
