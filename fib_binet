import math

def fib(n):
    if 1 <= int(n) <= 64:
        m_sqrt5 = math.sqrt(5)
        a = (1 + m_sqrt5) / 2
        b = (1 - m_sqrt5) / 2
        result = (a**int(n) - b**int(n)) / m_sqrt5
        # Округляем результат
        return round(result)
    else:
        raise ValueError("Число n должно быть в диапазоне 1 <= n <= 64")


n = input('Введите число: ')
result = fib(n)
print(f"Число Фибоначчи({n}) = {result}")
